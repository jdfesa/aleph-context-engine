# Aleph Context Engine Environment Configuration

# Provider de IA para formatear las notas (ollama, openai, groq, anthropic)
LLM_PROVIDER=ollama

# Modelo a utilizar (Ej: llama3, gpt-4o, mixtral)
LLM_MODEL=llama3

# API Key (Opcional si usas Ollama local)
LLM_API_KEY=ollama

# Base URL (Opcional, util para Ollama en local o proxies)
LLM_BASE_URL=http://localhost:11434/v1
